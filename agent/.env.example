# MarketPulse Agent — environment template.
# Copy to a private file you never commit, then `source` it (Git Bash) or set
# these in your shell before running cli.py. NEVER paste keys into .py files.

# --- Alpaca PAPER keys (get free at https://alpaca.markets -> Paper Trading) ---
export MP_ALPACA_KEY_ID="PKxxxxxxxxxxxxxxxxxx"
export MP_ALPACA_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Paper is the default. Set to "false" ONLY after weeks of proven paper results,
# and only with LIVE keys. There is no accidental path to real money.
export MP_ALPACA_PAPER="true"

# propose = agent only suggests; you approve each order by hand (recommended).
# auto    = agent sends within guardrails (do NOT use until paper-proven).
export MP_AGENT_MODE="propose"

# --- Risk caps (start tiny) -----------------------------------------------
export MP_PER_TRADE_USD="50"
export MP_MAX_SINGLE_TX_USD="100"
export MP_MAX_DAILY_SPEND_USD="400"
export MP_MAX_CONSECUTIVE_LOSSES="3"
export MP_MAX_DAILY_LOSS_PCT="0.05"
export MP_PROPOSAL_TTL="1800"

# --- Slippage band (our min_amount_out) -----------------------------------
# At approve time the agent pulls a LIVE price and refuses the order if the
# market moved against the side by more than this fraction since the signal.
# If a live price can't be fetched, the send fails closed.
export MP_MAX_SLIPPAGE_STOCK="0.005"    # 0.5%
export MP_MAX_SLIPPAGE_CRYPTO="0.015"   # 1.5%
